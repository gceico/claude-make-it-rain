{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-require-imports": "error",
    "no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ]
  },
  "ignorePatterns": [
    "/node_modules/",
    "/dist/",
    "/bin/",
    "/server/data/",
    "/web/",
    "/.claude/"
  ]
}
