# Dependencies
node_modules/
*.tgz

# Build output (bun build emits these; regenerated by `bun run build`)
dist/

# App data
server/data/

# Environment / secrets
.env
.env.*
!.env.example

# Local tool caches
.impeccable/

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude Code — track shared settings only; ignore local scratch
.claude/*
!.claude/settings.json
.claude/settings.local.json

# Local full-stack dev scratch (bun run start:all): dev DB + isolated userData
.dev/
