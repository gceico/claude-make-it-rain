---
// Site footer: social links (X / LinkedIn / GitHub), a "view source" pill, the
// privacy fine print, and the build credit.
import GithubIcon from './GithubIcon.astro';
const REPO_URL = 'https://github.com/gceico/claude-make-it-rain';
---

<footer class="site">
  <div class="socials">
    <a
      class="social"
      href="https://x.com/gceico"
      target="_blank"
      rel="noopener"
      aria-label="Gabriel on X"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true"
        ><path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        ></path></svg
      >
    </a>
    <a
      class="social"
      href="https://www.linkedin.com/in/gceico/"
      target="_blank"
      rel="noopener"
      aria-label="Gabriel on LinkedIn"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true"
        ><path
          d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"
        ></path></svg
      >
    </a>
    <a
      class="social"
      href="https://github.com/gceico"
      target="_blank"
      rel="noopener"
      aria-label="Gabriel on GitHub"
    >
      <GithubIcon />
    </a>
  </div>

  <div class="footlinks">
    <button class="source-link" type="button" data-about-open>
      About Make It Rain
    </button>
    <a class="source-link" href={REPO_URL} target="_blank" rel="noopener">
      <GithubIcon />
      View the source on GitHub
    </a>
  </div>

  <p class="fineprint">
    Only an anonymous tag and today's estimated total are ever shown. No
    accounts, no emails, no personal data. The leaderboard resets daily (UTC).
  </p>
  <p class="credit">
    Built by <a href="https://github.com/gceico" target="_blank" rel="noopener"
      >gceico</a
    >
  </p>
</footer>
