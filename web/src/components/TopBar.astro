---
// Fixed top-right GitHub "Star" pill. The live star count is filled in
// client-side from the same-origin GET /api/stars; until then (or on failure)
// the count stays hidden (.pending) and the pill simply links to the repo.
const REPO_URL = 'https://github.com/gceico/claude-make-it-rain';
---

<nav class="topbar">
  <a
    class="ghstar"
    id="ghstar"
    href={REPO_URL}
    target="_blank"
    rel="noopener"
    aria-label="View source on GitHub"
  >
    <svg viewBox="0 0 16 16" aria-hidden="true"
      ><path
        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
      ></path></svg
    >
    <span class="label">Star</span>
    <span class="divider"></span>
    <span class="count pending" id="starCount">
      <svg class="star-ico" viewBox="0 0 24 24" aria-hidden="true"
        ><path
          d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.169L12 18.896l-7.335 3.867 1.401-8.169L.132 9.21l8.2-1.192z"
        ></path></svg
      >
      <span id="starNum">—</span>
    </span>
  </a>
</nav>
