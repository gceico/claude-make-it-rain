---
import Install from "./Install.astro";

// Hero: wordmark, tagline, the "Today <date>" + "resets in <countdown>" pills,
// and today's COLLECTIVE tally — the whole community's combined spend, with a
// tangible equivalence — instead of a single top spender. The date, countdown,
// tally and equivalence values are populated client-side.
---

<header class="hero">
  <h1 class="wordmark"><span class="rain-emoji">💸</span> Make It Rain</h1>
  <p class="tagline">
    Every dollar of Claude&nbsp;Code spend, made impossible to ignore — and added
    up across everyone using it.
  </p>
  <Install />
  <div class="pills">
    <div class="datepill">
      <span class="dot"></span> Today <span class="date" id="date">…</span>
    </div>
    <div class="datepill reset">
      <span class="dot"></span> Resets in <span class="date" id="countdown"
        >…</span
      >
    </div>
  </div>

  <div class="tally" id="tally">
    <div class="amt" id="tallyAmt">$0.00</div>
    <p class="cap">
      Spent together today by <b id="tallyCount">0</b>
      <span id="tallyNoun"> builders</span>.<br />Each total updates every
      10&nbsp;min while their app is running.
    </p>
    <p class="collective-eq" id="collectiveEq"></p>
  </div>
</header>
