---
// Live daily leaderboard. Renders a shimmering skeleton (5 placeholder rows)
// until the client fetches GET /api/leaderboard, then swaps in the real rows,
// an empty state, or an error state (see lib/leaderboard.ts render/showError).
---

<section class="board skel" id="board" aria-live="polite" aria-busy="true">
  <div class="row">
    <div class="rank"></div>
    <div class="bar w-tag"></div>
    <div class="bar w-amt"></div>
  </div>
  <div class="row">
    <div class="rank"></div>
    <div class="bar w-tag"></div>
    <div class="bar w-amt"></div>
  </div>
  <div class="row">
    <div class="rank"></div>
    <div class="bar w-tag"></div>
    <div class="bar w-amt"></div>
  </div>
  <div class="row">
    <div class="rank"></div>
    <div class="bar w-tag"></div>
    <div class="bar w-amt"></div>
  </div>
  <div class="row">
    <div class="rank"></div>
    <div class="bar w-tag"></div>
    <div class="bar w-amt"></div>
  </div>
</section>
