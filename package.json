{
  "name": "@gceico/claude-make-it-rain",
  "version": "1.0.9",
  "description": "Satirical menu bar app that estimates today's Claude Code spend and makes it rain",
  "license": "MIT",
  "author": "Gabriel Ceicoschi <ceicoschi.gabriel@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gceico/claude-make-it-rain.git"
  },
  "homepage": "https://github.com/gceico/claude-make-it-rain#readme",
  "bugs": {
    "url": "https://github.com/gceico/claude-make-it-rain/issues"
  },
  "main": "dist/main.js",
  "bin": {
    "claude-make-it-rain": "bin/make-it-rain.js"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.12",
  "keywords": [
    "electron",
    "tray",
    "menubar",
    "claude",
    "claude-code",
    "overlay"
  ],
  "files": [
    "dist",
    "bin/make-it-rain.js",
    "overlay.html",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "trustedDependencies": [
    "electron"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "start": "bun run build && electron .",
    "start:all": "bun run scripts/dev-all.ts",
    "dev": "bun run build && electron .",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:app": "bun test test/usage-monitor.test.ts test/delight.test.ts test/equivalences.test.ts test/leaderboard-client.test.ts test/history.test.ts test/update-checker.test.ts",
    "test:server": "bun test test/leaderboard-db.test.ts test/leaderboard-server.test.ts",
    "test": "bun run test:app && bun run test:server",
    "prepublishOnly": "bun run build && bun run test:app"
  },
  "dependencies": {
    "electron": "^43.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
